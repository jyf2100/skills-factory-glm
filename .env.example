# Gitea Configuration
# Uncomment and set these values to enable remote repository integration

# Gitea repository URL (must end with .git)
# GITEA_URL=https://gitea.example.com/skills.git

# Gitea authentication token
# Generate this in your Gitea instance: Settings -> Applications -> Generate Token
# GITEA_TOKEN=your-token-here

# GitLab Configuration
# Local GitLab instance for skills data source

# GitLab URL (e.g., https://gitlab.example.com)
# GITLAB_URL=https://gitlab.example.com

# GitLab Personal Access Token
# Generate in GitLab: Settings -> Access Tokens
# GITLAB_TOKEN=your-token-here

# GitLab group/project for skills (e.g., my-org/skills)
# GITLAB_SKILLS_PROJECT=my-org/skills

# GitHub Configuration
# GitHub repository for skills synchronization

# GitHub repository URL (e.g., https://github.com/owner/repo.git)
# GITHUB_URL=https://github.com/owner/repo.git

# GitHub Personal Access Token
# Generate in GitHub: Settings -> Developer settings -> Personal access tokens
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxx
